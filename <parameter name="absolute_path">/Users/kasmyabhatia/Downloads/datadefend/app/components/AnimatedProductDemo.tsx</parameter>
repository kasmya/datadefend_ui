// Radial Progress Ring Component
function RadialProgress({ value, size = "normal" }: { value: number; size?: "normal" | "small" }) {
    const circumference = 2 * Math.PI * 28;
    const offset = circumference - (value / 100) * circumference;
    
    const dimensions = size === "small" ? { w: 48, r: 20 } : { w: 64, r: 28 };
    
    return (
        <div className={`relative w-${dimensions.w} h-${dimensions.w}`}>
            <svg width={dimensions.w} height={dimensions.w} viewBox={`0 0 ${dimensions.w} ${dimensions.w}`} className="transform -rotate-90">
                <circle
                    cx={dimensions.r}
                    cy={dimensions.r}
                    r={dimensions.r}
                    fill="none"
                    stroke="rgba(255,255,255,0.1)"
                    strokeWidth="4"
                />
                <circle
                    cx={dimensions.r}
                    cy={dimensions.r}
                    r={dimensions.r}
                    fill="none"
                    stroke="#10B981"
                    strokeWidth="4"
                    strokeLinecap="round"
                    strokeDasharray={circumference}
                    strokeDashoffset={offset}
                    className="transition-all duration-1000"
                />
            </svg>
            <div className="absolute inset-0 flex items-center justify-center">
                <span className={`font-bold text-${size === "small" ? "xs" : "sm"} text-white`}>{value}%</span>
            </div>
    );
}

// Segmented Progress Bar
function SegmentedProgress({ segments = 5, filled = 5 }: { segments?: number; filled?: number }) {
    return (
        <div className="flex gap-1">
            {Array.from({ length: segments }).map((_, i) => (
                <div 
                    key={i} 
                    className={`h-2 flex-1 rounded-full ${i < filled ? 'bg-emerald-400 shadow-lg shadow-emerald-400/50' : 'bg-white/10'}`}
                />
            ))}
        </div>
    );
}

// Trend Line Component
